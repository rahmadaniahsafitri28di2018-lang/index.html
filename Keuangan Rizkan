/* =====================================================================
 * KODE GOOGLE APPS SCRIPT: THREE-WAY INTEGRATED CONTROLLER (V2.5)
 * =====================================================================
 * Hubungkan Google Sheets, WhatsApp, dan Dashboard secara terpadu.
 * Mendukung GET (mengirim data ke Web) dan POST (menerima input WA & Manual Web).
 */

// 1. PENGATURAN UTAMA (WAJIB DIISI)
var SPREADSHEET_ID = "MASUKKAN_ID_SPREADSHEET_ANDA_DI_SINI"; 
var SHEET_NAME = "Transaksi";

// 2. INTEGRASI BALASAN WHATSAPP (Wajib diisi agar bot membalas pesan otomatis)
var WA_PROVIDER = "GREEN_API"; // Pilihan: "GREEN_API" | "ULTRAMSG" | "NONE"
var WA_API_URL = "https://api.green-api.com"; 
var WA_INSTANCE_ID = "YOUR_INSTANCE_ID";      
var WA_TOKEN = "YOUR_API_TOKEN_KEY";          

// A. MENANGANI PENGAMBILAN DATA (Untuk Dashboard Tampilan Live Sync)
function doGet(e) {
  try {
    var ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAME);
    
    if (!sheet) {
      return ContentService.createTextOutput(JSON.stringify({ "status": "error", "message": "Sheet Transaksi belum dibuat." }))
                           .setMimeType(ContentService.MimeType.JSON)
                           .setHeaders({ "Access-Control-Allow-Origin": "*" });
    }
    
    var values = sheet.getDataRange().getValues();
    var transactions = [];
    
    // Looping data mulai dari baris kedua (lewati header)
    for (var i = 1; i < values.length; i++) {
      var row = values[i];
      if (!row[0]) continue;
      
      transactions.push({
        id: "tx-sheet-" + i,
        date: row[0],
        type: row[1].toString().toLowerCase(),
        category: row[2],
        amount: parseFloat(row[3]) || 0,
        desc: row[4],
        source: row[5] || "WhatsApp"
      });
    }
    
    return ContentService.createTextOutput(JSON.stringify({ "status": "success", "data": transactions }))
                         .setMimeType(ContentService.MimeType.JSON)
                         .setHeaders({ "Access-Control-Allow-Origin": "*" });
                         
  } catch(err) {
    return ContentService.createTextOutput(JSON.stringify({ "status": "error", "message": err.toString() }))
                         .setMimeType(ContentService.MimeType.JSON)
                         .setHeaders({ "Access-Control-Allow-Origin": "*" });
  }
}

// B. MENANGANI PENULISAN DATA (Menerima input dari WhatsApp & Manual Web)
function doPost(e) {
  try {
    if (!e || !e.postData || !e.postData.contents) {
      return ContentService.createTextOutput(JSON.stringify({ "status": "error", "message": "Payload kosong" }))
                           .setMimeType(ContentService.MimeType.JSON)
                           .setHeaders({ "Access-Control-Allow-Origin": "*" });
    }

    var payload = JSON.parse(e.postData.contents);
    
    // Buka spreadsheet secara global
    var ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    var sheet = ss.getSheetByName(SHEET_NAME);
    
    if (!sheet) {
      sheet = ss.insertSheet(SHEET_NAME);
      sheet.appendRow(["Tanggal", "Tipe", "Kategori", "Nominal", "Keterangan", "Pengirim"]);
      sheet.getRange(1, 1, 1, 6).setFontWeight("bold").setBackground("#f1f5f9");
      sheet.setFrozenRows(1);
    }

    // APAKAH INPUT BERASAL DARI WEB MANUAL?
    if (payload.action === "manual_web_input") {
      sheet.appendRow([
        new Date(payload.date),
        payload.type,
        payload.category,
        payload.amount,
        payload.desc,
        "Web Dashboard"
      ]);
      return ContentService.createTextOutput(JSON.stringify({ "status": "success" }))
                           .setMimeType(ContentService.MimeType.JSON)
                           .setHeaders({ "Access-Control-Allow-Origin": "*" });
    }

    // JIKA BUKAN MANUAL, BERARTI PAYLOAD WHATSAPP WEBHOOK
    var messageText = "";
    var senderNumber = "";

    if (payload.messageData && payload.messageData.textMessageData) {
      messageText = payload.messageData.textMessageData.textMessage;
      senderNumber = payload.senderData.sender.replace("@c.us", "");
    } else if (payload.body) {
      messageText = payload.body;
      senderNumber = (payload.from || payload.sender || "").replace(/[^0-9]/g, "");
    } else {
      messageText = payload.message || payload.text || "";
      senderNumber = (payload.sender || "628xxx").replace(/[^0-9]/g, "");
    }

    messageText = messageText.trim();
    if (!messageText) return ContentService.createTextOutput("Pesan kosong.");

    var isIncome = messageText.startsWith("+");
    var isExpense = messageText.startsWith("-");
    var isStatusCheck = messageText.toLowerCase() === "status";

    var responseMessage = "";

    if (isStatusCheck) {
      responseMessage = generateStatusReport(sheet);
    } else if (isIncome || isExpense) {
      var cleanText = messageText.substring(1).trim(); 
      var parts = cleanText.split(" ");
      var rawAmountText = parts[0]; 
      
      var amount = parseNominalSmart(rawAmountText);
      
      if (amount <= 0) {
        responseMessage = "⚠️ *Format Salah!*\nNominal tidak valid. Gunakan angka.\n" +
                          "Contoh:\n" +
                          "• `+ 5jt Gaji`\n" +
                          "• `- 50k Kopi`";
      } else {
        parts.shift(); 
        var textRemain = parts.join(" ");
        
        var category = "";
        var hashtagIndex = textRemain.indexOf("#");
        if (hashtagIndex !== -1) {
          category = textRemain.substring(hashtagIndex + 1).trim();
          textRemain = textRemain.substring(0, hashtagIndex).trim();
        }

        if (!category) {
          category = isIncome ? "Pembagian Auto" : "Kebutuhan"; 
        }

        var dateNow = new Date();
        var type = isIncome ? "Pemasukan" : "Pengeluaran";

        // Simpan baris baru ke Sheet
        sheet.appendRow([
          dateNow,
          type,
          category,
          amount,
          textRemain || (isIncome ? "Pemasukan tanpa keterangan" : "Pengeluaran tanpa keterangan"),
          senderNumber
        ]);

        var typeLabel = isIncome ? "📥 Pemasukan" : "📤 Pengeluaran";
        
        // Buat kalkulasi saldo terkini
        var currentStatus = getQuickBalance(sheet);
        
        responseMessage = "✅ *" + typeLabel + " Berhasil Dicatat!*\n" +
                          "━━━━━━━━━━━━━━━\n" +
                          "• Nominal: *Rp " + amount.toLocaleString("id-ID") + "*\n" +
                          "• Detail: _" + textRemain + "_\n" +
                          "• Alokasi: *" + category + "*\n" +
                          "• Waktu: " + Utilities.formatDate(dateNow, "GMT+7", "dd-MM-yyyy HH:mm") + " WIB\n" +
                          "━━━━━━━━━━━━━━━\n" +
                          "💰 *SISA SALDO KAS: Rp " + currentStatus.balance.toLocaleString("id-ID") + "*\n" +
                          "_Ketik *status* untuk melihat sisa saku lengkap._";
      }
    } else {
      responseMessage = "❓ *Format Tidak Dikenali*\n\n" +
                        "Gunakan format pencatatan berikut:\n" +
                        "• *Pemasukan*: `+ [nominal] [keterangan]`\n" +
                        "• *Pengeluaran*: `- [nominal] [keterangan]`\n" +
                        "Contoh: `- 150k Belanja Bulanan #Kebutuhan`";
    }

    // Kirim Balasan Pesan via WhatsApp
    sendWhatsAppReply(senderNumber, responseMessage);

    return ContentService.createTextOutput(JSON.stringify({ "status": "success", "reply": responseMessage }))
                         .setMimeType(ContentService.MimeType.JSON)
                         .setHeaders({ "Access-Control-Allow-Origin": "*" });

  } catch(error) {
    return ContentService.createTextOutput(JSON.stringify({ "status": "error", "message": error.toString() }))
                         .setMimeType(ContentService.MimeType.JSON)
                         .setHeaders({ "Access-Control-Allow-Origin": "*" });
  }
}

// Fungsi Pintar membaca: 50k, 1.5jt, 250rb, dsb.
function parseNominalSmart(str) {
  if (!str) return 0;
  str = str.toLowerCase().replace(/rp/g, "").trim();
  var multiplier = 1;
  
  if (str.endsWith("jt") || str.endsWith("juta")) {
    multiplier = 1000000;
    str = str.replace(/(jt|juta)/g, "");
  } else if (str.endsWith("k")) {
    multiplier = 1000;
    str = str.replace(/k/g, "");
  } else if (str.endsWith("rb") || str.endsWith("ribu")) {
    multiplier = 1000;
    str = str.replace(/(rb|ribu)/g, "");
  }

  if (multiplier === 1000000 || multiplier === 1000) {
    str = str.replace(/,/g, ".");
  } else {
    if (str.includes(".") && str.includes(",")) {
      str = str.replace(/\./g, "").replace(/,/g, ".");
    } else if (str.includes(",")) {
      if (str.match(/,\d{3}$/)) {
        str = str.replace(/,/g, ""); 
      } else {
        str = str.replace(/,/g, "."); 
      }
    } else if (str.includes(".")) {
      if (str.match(/\.\d{3}$/)) {
        str = str.replace(/\./g, "");
      }
    }
  }

  var parsedValue = parseFloat(str);
  return isNaN(parsedValue) ? 0 : parsedValue * multiplier;
}

function getQuickBalance(sheet) {
  var rows = sheet.getDataRange().getValues();
  var income = 0;
  var expense = 0;
  for (var i = 1; i < rows.length; i++) {
    var type = rows[i][1];
    var amount = parseFloat(rows[i][3]) || 0;
    if (type === "Pemasukan") income += amount;
    else if (type === "Pengeluaran") expense += amount;
  }
  return { balance: (income - expense) };
}

function generateStatusReport(sheet) {
  var rows = sheet.getDataRange().getValues();
  var totalIncome = 0;
  var totalExpense = 0;
  
  for (var i = 1; i < rows.length; i++) {
    var type = rows[i][1];
    var amount = parseFloat(rows[i][3]) || 0;
    if (type === "Pemasukan") totalIncome += amount;
    else if (type === "Pengeluaran") totalExpense += amount;
  }
  
  var balance = totalIncome - totalExpense;
  return "📊 *STATUS DOMPET KITA SAAT INI*\n" +
         "━━━━━━━━━━━━━━━\n" +
         "📥 Total Masuk: *Rp " + totalIncome.toLocaleString("id-ID") + "*\n" +
         "📤 Total Keluar: *Rp " + totalExpense.toLocaleString("id-ID") + "*\n" +
         "💰 *SISA SALDO KAS: Rp " + balance.toLocaleString("id-ID") + "*\n" +
         "━━━━━━━━━━━━━━━\n" +
         "_Laporan tersinkron aman di Google Sheets & Web Dashboard_";
}

function sendWhatsAppReply(to, text) {
  if (WA_PROVIDER === "NONE" || WA_INSTANCE_ID === "YOUR_INSTANCE_ID") {
    Logger.log("Pengiriman WA dilewati (Belum dikonfigurasi).");
    return;
  }

  var url = "";
  var payload = {};

  if (WA_PROVIDER === "GREEN_API") {
    url = WA_API_URL + "/waInstance" + WA_INSTANCE_ID + "/sendMessage/" + WA_TOKEN;
    payload = {
      "chatId": to.includes("@") ? to : to + "@c.us",
      "message": text
    };
  } else if (WA_PROVIDER === "ULTRAMSG") {
    url = WA_API_URL + "/" + WA_INSTANCE_ID + "/messages/chat";
    payload = {
      "token": WA_TOKEN,
      "to": to,
      "body": text
    };
  }

  try {
    UrlFetchApp.fetch(url, {
      "method": "post",
      "contentType": "application/json",
      "payload": JSON.stringify(payload),
      "muteHttpExceptions": true
    });
  } catch(e) {
    Logger.log("Error mengirim pesan WA: " + e.toString());
  }
}</pre>
                    </div>
                </div>
            </div>
        </div>
