    <script>
        /* 1. Core State Management */
        let state = {
            transactions: [],
            allocations: [],
            manualType: 'pemasukan',
            isLiveSync: false,
            gasUrl: ''
        };

        const presetAllocations_50_30_20 = [
            { id: 'all-1', name: 'Kebutuhan', percent: 50, limit: 1500000, spent: 0 },
            { id: 'all-2', name: 'Keinginan', percent: 30, limit: 900000, spent: 0 },
            { id: 'all-3', name: 'Tabungan', percent: 20, limit: 600000, spent: 0 }
        ];

        const initialSeedTransactions = [
            { id: 'tx-1', date: new Date(Date.now() - 3 * 24 * 60 * 60 * 1000), type: 'pemasukan', category: 'Pembagian Auto', amount: 3000000, desc: 'Gaji Bulanan Utama', source: 'WhatsApp' },
            { id: 'tx-2', date: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000), type: 'pengeluaran', category: 'Kebutuhan', amount: 350000, desc: 'Belanja Bulanan Supermarket', source: 'WhatsApp' },
            { id: 'tx-3', date: new Date(Date.now() - 1 * 24 * 60 * 60 * 1000), type: 'pengeluaran', category: 'Keinginan', amount: 120000, desc: 'Nonton Bioskop & Snack', source: 'Manual' },
            { id: 'tx-4', date: new Date(), type: 'pengeluaran', category: 'Kebutuhan', amount: 45000, desc: 'Beli Token Listrik', source: 'WhatsApp' }
        ];

        let expenseChart = null;

        window.onload = function() {
            const storedAllocations = localStorage.getItem('keukita_allocations');
            const storedGasUrl = localStorage.getItem('keukita_gas_url');
            const storedLiveMode = localStorage.getItem('keukita_live_mode');

            if (storedAllocations) {
                state.allocations = JSON.parse(storedAllocations);
            } else {
                state.allocations = [...presetAllocations_50_30_20];
            }

            if (storedGasUrl) {
                state.gasUrl = storedGasUrl;
                document.getElementById('gas-url-input').value = storedGasUrl;
            }

            if (storedLiveMode === 'true' && state.gasUrl) {
                activateLiveSyncMode(state.gasUrl);
            } else {
                loadLocalTransactions();
            }

            renderAllocationsEditor();
            populateManualFormCategories();
            initChart();
        };

        function loadLocalTransactions() {
            const storedTransactions = localStorage.getItem('keukita_txs');
            if (storedTransactions) {
                state.transactions = JSON.parse(storedTransactions).map(tx => ({...tx, date: new Date(tx.date)}));
            } else {
                state.transactions = [...initialSeedTransactions];
            }
            state.isLiveSync = false;
            updateSyncUI();
            calculateFinancialState();
            renderDashboard();
            renderTransactionsList();
        }

        function formatRupiah(number) {
            return new Intl.NumberFormat('id-ID', {
                style: 'currency',
                currency: 'IDR',
                maximumFractionDigits: 0
            }).format(number);
        }

        function showToast(message, isSuccess = true) {
            const toast = document.getElementById('custom-toast');
            const toastMessage = document.getElementById('toast-message');
            const toastIcon = document.getElementById('toast-icon');

            toastMessage.textContent = message;
            if (isSuccess) {
                toastIcon.className = "p-1 bg-emerald-500 rounded-lg text-white";
                toastIcon.innerHTML = `<i class="fa-solid fa-check"></i>`;
            } else {
                toastIcon.className = "p-1 bg-rose-500 rounded-lg text-white";
                toastIcon.innerHTML = `<i class="fa-solid fa-circle-exclamation"></i>`;
            }

            toast.classList.remove('translate-y-24', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                toast.classList.add('translate-y-24', 'opacity-0');
                toast.classList.remove('translate-y-0', 'opacity-100');
            }, 3000);
        }

        async function testAndSaveLiveSync() {
            const urlInput = document.getElementById('gas-url-input').value.trim();
            if (!urlInput) {
                showToast("URL Google Apps Script tidak boleh kosong!", false);
                return;
            }

            showToast("Menghubungkan ke Google Sheets...", true);

            try {
                // Testing GET connection to Google Apps Script
                const response = await fetch(urlInput);
                const result = await response.json();

                if (result.status === 'success') {
                    state.gasUrl = urlInput;
                    localStorage.setItem('keukita_gas_url', urlInput);
                    localStorage.setItem('keukita_live_mode', 'true');
                    
                    activateLiveSyncMode(urlInput, result.data);
                    showToast("Dasbor Terkoneksi ke Google Sheets!");
                } else {
                    showToast("Gagal terhubung: " + result.message, false);
                }
            } catch (error) {
                console.error("Fetch error:", error);
                showToast("Gagal terhubung. Pastikan Web App diset ke 'Anyone' & dukung CORS.", false);
            }
        }

        function activateLiveSyncMode(url, loadedData = null) {
            state.isLiveSync = true;
            state.gasUrl = url;
            
            if (loadedData) {
                state.transactions = loadedData.map(tx => ({...tx, date: new Date(tx.date)}));
                finishSyncLoad();
            } else {
                fetchLiveTransactions();
            }
        }

        async function fetchLiveTransactions() {
            if (!state.gasUrl) return;
            try {
                const response = await fetch(state.gasUrl);
                const result = await response.json();
                if (result.status === 'success') {
                    state.transactions = result.data.map(tx => ({...tx, date: new Date(tx.date)}));
                    finishSyncLoad();
                }
            } catch (e) {
                showToast("Gagal memuat data dari Google Sheets.", false);
                loadLocalTransactions();
            }
        }

        function finishSyncLoad() {
            updateSyncUI();
            calculateFinancialState();
            renderDashboard();
            renderTransactionsList();
            updateChart();
        }

        function disableLiveSync() {
            localStorage.setItem('keukita_live_mode', 'false');
            loadLocalTransactions();
            showToast("Mode Live Sync dinonaktifkan.");
        }

        function updateSyncUI() {
            const badge = document.getElementById('integration-status');
            const syncBadge = document.getElementById('sync-badge');
            const dot = document.getElementById('indicator-dot');
            const text = document.getElementById('indicator-text');
            const disableBtn = document.getElementById('btn-disable-sync');
            const banner = document.getElementById('alert-banner');

            if (state.isLiveSync) {
                badge.className = "flex items-center bg-indigo-100 text-indigo-800 text-xs px-2.5 py-1 rounded-full font-semibold animate-pulse";
                badge.innerHTML = `<span class="w-2 h-2 bg-indigo-500 rounded-full mr-1.5"></span>Mode Live: Aktif`;
                syncBadge.className = "hidden sm:inline-block ml-2 text-xs bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded-full border border-indigo-200 font-medium";
                syncBadge.textContent = "Sheets Live";
                
                dot.className = "w-2.5 h-2.5 bg-indigo-500 rounded-full inline-block animate-ping";
                text.textContent = "Status: Terkoneksi Riil dengan Google Sheets";
                disableBtn.classList.remove('hidden');
                
                // Hide simulator banner if already live
                if (banner) banner.classList.add('hidden');
            } else {
                badge.className = "flex items-center bg-emerald-100 text-emerald-800 text-xs px-2.5 py-1 rounded-full font-semibold";
                badge.innerHTML = `<span class="w-2 h-2 bg-emerald-500 rounded-full mr-1.5 animate-pulse"></span>Simulasi Aktif`;
                syncBadge.className = "hidden sm:inline-block ml-2 text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full border border-emerald-200 font-medium";
                syncBadge.textContent = "Auto-Sync";

                dot.className = "w-2.5 h-2.5 bg-slate-300 rounded-full inline-block";
                text.textContent = "Status: Offline / Mode Simulasi Aktif";
                disableBtn.classList.add('hidden');
                if (banner) banner.classList.remove('hidden');
            }
        }

        function calculateFinancialState() {
            let totalIncome = state.transactions
                .filter(tx => tx.type === 'pemasukan')
                .reduce((sum, tx) => sum + tx.amount, 0);

            state.allocations.forEach(alloc => {
                alloc.limit = totalIncome * (alloc.percent / 100);
                alloc.spent = 0;
            });

            state.transactions.forEach(tx => {
                if (tx.type === 'pengeluaran') {
                    let matchingAlloc = state.allocations.find(a => a.name.toLowerCase() === tx.category.toLowerCase());
                    if (matchingAlloc) {
                        matchingAlloc.spent += tx.amount;
                    } else {
                        if (state.allocations.length > 0) {
                            state.allocations[0].spent += tx.amount;
                        }
                    }
                }
            });

            if (!state.isLiveSync) {
                localStorage.setItem('keukita_txs', JSON.stringify(state.transactions));
            }
            localStorage.setItem('keukita_allocations', JSON.stringify(state.allocations));
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.add('hidden');
                content.classList.remove('block');
            });

            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('border-emerald-600', 'text-emerald-600', 'active');
                btn.classList.add('border-transparent', 'text-slate-500');
            });

            document.getElementById(`content-${tabId}`).classList.remove('hidden');
            document.getElementById(`content-${tabId}`).classList.add('block');

            const activeBtn = document.getElementById(`tab-${tabId}`);
            activeBtn.classList.add('border-emerald-600', 'text-emerald-600', 'active');
            activeBtn.classList.remove('border-transparent', 'text-slate-500');

            if (tabId === 'dashboard') {
                if (state.isLiveSync) {
                    fetchLiveTransactions();
                } else {
                    calculateFinancialState();
                    renderDashboard();
                    updateChart();
                }
            }
        }

        // Render Dashboard View
        function renderDashboard() {
            let totalIncome = 0;
            let totalExpense = 0;
            let incomeCount = 0;
            let expenseCount = 0;

            state.transactions.forEach(tx => {
                if (tx.type === 'pemasukan') {
                    totalIncome += tx.amount;
                    incomeCount++;
                } else {
                    totalExpense += tx.amount;
                    expenseCount++;
                }
            });

            let balance = totalIncome - totalExpense;
            let savingsRate = totalIncome > 0 ? Math.max(0, Math.round((balance / totalIncome) * 100)) : 0;

            document.getElementById('dash-balance').textContent = formatRupiah(balance);
            document.getElementById('dash-income').textContent = formatRupiah(totalIncome);
            document.getElementById('dash-income-count').textContent = `${incomeCount} transaksi`;
            document.getElementById('dash-expense').textContent = formatRupiah(totalExpense);
            document.getElementById('dash-expense-count').textContent = `${expenseCount} transaksi`;
            document.getElementById('dash-savings-rate').textContent = `${savingsRate}%`;
            document.getElementById('dash-savings-bar').style.width = `${Math.min(100, savingsRate)}%`;

            const progressContainer = document.getElementById('allocation-progress-container');
            progressContainer.innerHTML = '';

            state.allocations.forEach(alloc => {
                let percentUsed = alloc.limit > 0 ? Math.round((alloc.spent / alloc.limit) * 100) : 0;
                let isOverBudget = percentUsed > 100;
                let barColorClass = "bg-emerald-500";
                
                if (percentUsed > 80 && percentUsed <= 100) {
                    barColorClass = "bg-amber-500";
                } else if (percentUsed > 100) {
                    barColorClass = "bg-rose-500 animate-pulse";
                }

                const cardHTML = `
                    <div class="p-4 border border-slate-100 bg-slate-50/50 rounded-xl space-y-2">
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center text-sm gap-1">
                            <div class="flex items-center space-x-2">
                                <span class="font-bold text-slate-800 text-sm">${alloc.name}</span>
                                <span class="text-xs bg-slate-200 text-slate-600 px-2 py-0.5 rounded-full font-bold">${alloc.percent}% Alokasi</span>
                            </div>
                            <div class="text-xs text-slate-500">
                                <strong class="text-slate-800">${formatRupiah(alloc.spent)}</strong> dari limit <span class="font-medium">${formatRupiah(alloc.limit)}</span>
                            </div>
                        </div>
                        <div class="w-full bg-slate-200 h-2.5 rounded-full overflow-hidden relative">
                            <div class="h-full rounded-full transition-all duration-500 ${barColorClass}" style="width: ${Math.min(100, percentUsed)}%"></div>
                        </div>
                        <div class="flex justify-between items-center text-[11px]">
                            <span class="${isOverBudget ? 'text-rose-600 font-bold' : 'text-slate-500'}">
                                ${isOverBudget ? `⚠️ Overbudget Rp ${Math.abs(alloc.limit - alloc.spent).toLocaleString('id-ID')}` : 'Anggaran sehat'}
                            </span>
                            <span class="font-semibold text-slate-600">${percentUsed}% digunakan</span>
                        </div>
                    </div>
                `;
                progressContainer.insertAdjacentHTML('beforeend', cardHTML);
            });
        }

        function setManualType(type) {
            state.manualType = type;
            const btnIncome = document.getElementById('btn-type-income');
            const btnExpense = document.getElementById('btn-type-expense');

            if (type === 'pemasukan') {
                btnIncome.className = "py-2 rounded-xl text-sm font-bold border-2 border-emerald-500 bg-emerald-50 text-emerald-700 flex items-center justify-center space-x-1.5 transition";
                btnExpense.className = "py-2 rounded-xl text-sm font-bold border border-slate-200 text-slate-600 flex items-center justify-center space-x-1.5 transition";
            } else {
                btnExpense.className = "py-2 rounded-xl text-sm font-bold border-2 border-rose-500 bg-rose-50 text-rose-700 flex items-center justify-center space-x-1.5 transition";
                btnIncome.className = "py-2 rounded-xl text-sm font-bold border border-slate-200 text-slate-600 flex items-center justify-center space-x-1.5 transition";
            }
        }

        function populateManualFormCategories() {
            const dropdown = document.getElementById('man-category');
            dropdown.innerHTML = '';
            
            const optAuto = document.createElement('option');
            optAuto.value = 'Pembagian Auto';
            optAuto.textContent = 'Auto-Bagi (Sesuai Aturan Alokasi)';
            dropdown.appendChild(optAuto);

            state.allocations.forEach(alloc => {
                const opt = document.createElement('option');
                opt.value = alloc.name;
                opt.textContent = alloc.name;
                dropdown.appendChild(opt);
            });
        }

        async function handleManualSubmit(e) {
            e.preventDefault();
            const amountInput = document.getElementById('man-amount');
            const descInput = document.getElementById('man-desc');
            const catInput = document.getElementById('man-category');

            const nominal = parseFloat(amountInput.value);
            const desc = descInput.value.trim();
            const category = catInput.value;

            if (isNaN(nominal) || nominal <= 0 || !desc) {
                showToast("Data tidak valid!", false);
                return;
            }

            const newTx = {
                id: 'tx-' + Date.now(),
                date: new Date(),
                type: state.manualType,
                category: category,
                amount: nominal,
                desc: desc,
                source: 'Manual'
            };

            if (state.isLiveSync) {
                showToast("Menyimpan ke Google Sheets...", true);
                try {
                    const response = await fetch(state.gasUrl, {
                        method: 'POST',
                        mode: 'no-cors', // default response redirection
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            action: 'manual_web_input',
                            date: newTx.date.toISOString(),
                            type: newTx.type === 'pemasukan' ? 'Pemasukan' : 'Pengeluaran',
                            category: newTx.category,
                            amount: newTx.amount,
                            desc: newTx.desc
                        })
                    });
                    
                    // fetch newest data because mode: no-cors doesn't give payload body back
                    setTimeout(() => {
                        fetchLiveTransactions();
                        showToast("Manual Berhasil Tersimpan!");
                    }, 1200);

                } catch (err) {
                    showToast("Gagal menyimpan ke Google Sheets.", false);
                }
            } else {
                state.transactions.unshift(newTx);
                calculateFinancialState();
                renderDashboard();
                renderTransactionsList();
                updateChart();
                showToast("Transaksi Berhasil Ditambahkan!");
            }
            
            amountInput.value = '';
            descInput.value = '';
        }

        function renderTransactionsList() {
            const container = document.getElementById('transaction-list-container');
            const emptyState = document.getElementById('transactions-empty-state');

            container.innerHTML = '';

            if (state.transactions.length === 0) {
                emptyState.classList.remove('hidden');
                return;
            } else {
                emptyState.classList.add('hidden');
            }

            state.transactions.forEach(tx => {
                let dateFormatted = tx.date.toLocaleDateString('id-ID', {
                    day: 'numeric', month: 'short', year: 'numeric'
                });

                let signClass = tx.type === 'pemasukan' ? 'text-emerald-600 bg-emerald-50 border-emerald-100' : 'text-rose-600 bg-rose-50 border-rose-100';
                let sign = tx.type === 'pemasukan' ? '+' : '-';
                let iconClass = tx.type === 'pemasukan' ? 'fa-solid fa-arrow-down' : 'fa-solid fa-arrow-up';
                let originBadge = tx.source === 'WhatsApp' ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-800';
                let originIcon = tx.source === 'WhatsApp' ? 'fa-brands fa-whatsapp text-emerald-500' : 'fa-solid fa-keyboard text-slate-400';

                const rowHTML = `
                    <div class="p-3 border border-slate-100 hover:border-slate-200 bg-white rounded-xl flex items-center justify-between shadow-sm transition">
                        <div class="flex items-center space-x-3 truncate">
                            <span class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold border ${signClass}">
                                <i class="${iconClass}"></i>
                            </span>
                            <div class="truncate">
                                <h4 class="font-semibold text-slate-800 text-xs sm:text-sm truncate">${tx.desc}</h4>
                                <div class="flex items-center space-x-2 text-[10px] text-slate-400 mt-1">
                                    <span>${dateFormatted}</span>
                                    <span>•</span>
                                    <span class="bg-indigo-50 text-indigo-700 px-1.5 py-0.2 rounded font-semibold uppercase tracking-wider text-[8px]">${tx.category}</span>
                                </div>
                            </div>
                        </div>

                        <div class="flex flex-col items-end space-y-1">
                            <span class="font-bold text-xs sm:text-sm ${tx.type === 'pemasukan' ? 'text-emerald-600' : 'text-rose-600'}">
                                ${sign} ${formatRupiah(tx.amount)}
                            </span>
                            <span class="text-[9px] px-1.5 py-0.5 rounded-full font-bold flex items-center space-x-1 ${originBadge}">
                                <i class="${originIcon} text-[9px] mr-1"></i>
                                <span>${tx.source}</span>
                            </span>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', rowHTML);
            });
        }

        function clearAllTransactions() {
            if (confirm("Apakah Anda yakin ingin menghapus semua catatan transaksi simulasi?")) {
                if (state.isLiveSync) {
                    showToast("Gagal! Untuk live mode, silakan hapus data manual dari Google Spreadsheet Anda.", false);
                    return;
                }
                state.transactions = [];
                calculateFinancialState();
                renderDashboard();
                renderTransactionsList();
                updateChart();
                showToast("Semua transaksi berhasil dibersihkan.");
            }
        }

        function exportToCSV() {
            if (state.transactions.length === 0) {
                showToast("Tidak ada data untuk diekspor!", false);
                return;
            }

            let csvContent = "data:text/csv;charset=utf-8,";
            csvContent += "ID,Tanggal,Tipe,Kategori,Nominal,Keterangan,Sumber\n";

            state.transactions.forEach(tx => {
                let row = `"${tx.id}","${tx.date.toISOString()}","${tx.type}","${tx.category}",${tx.amount},"${tx.desc.replace(/"/g, '""')}","${tx.source}"`;
                csvContent += row + "\n";
            });

            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", `keukita_keuangan_export_${Date.now()}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            showToast("File CSV Berhasil Diunduh!");
        }

        // Preset allocations handler
        function applyPreset(presetType) {
            const preset50 = document.getElementById('preset-50-30-20');
            const preset70 = document.getElementById('preset-70-20-10');
            const presetCust = document.getElementById('preset-custom');

            [preset50, preset70, presetCust].forEach(el => {
                el.className = "p-4 border border-slate-200 rounded-2xl text-left hover:border-emerald-500 transition focus:outline-none";
            });

            if (presetType === '50/30/20') {
                preset50.className = "p-4 border-2 border-emerald-500 bg-emerald-50/50 rounded-2xl text-left hover:border-emerald-500 transition focus:outline-none";
                state.allocations = [...presetAllocations_50_30_20];
            } else if (presetType === '70/20/10') {
                preset70.className = "p-4 border-2 border-emerald-500 bg-emerald-50/50 rounded-2xl text-left hover:border-emerald-500 transition focus:outline-none";
                state.allocations = [
                    { id: 'all-1', name: 'Kebutuhan', percent: 70, limit: 0, spent: 0 },
                    { id: 'all-2', name: 'Tabungan', percent: 20, limit: 0, spent: 0 },
                    { id: 'all-3', name: 'Donasi/Zakat', percent: 10, limit: 0, spent: 0 }
                ];
            } else {
                presetCust.className = "p-4 border-2 border-emerald-500 bg-emerald-50/50 rounded-2xl text-left hover:border-emerald-500 transition focus:outline-none";
            }

            renderAllocationsEditor();
            checkPercentageSum();
            populateManualFormCategories();
        }

        function renderAllocationsEditor() {
            const container = document.getElementById('categories-editor-container');
            container.innerHTML = '';

            state.allocations.forEach((alloc, index) => {
                const rowHTML = `
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center bg-slate-50 p-3.5 rounded-xl border border-slate-200">
                        <div class="md:col-span-5">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Nama Kategori Anggaran</label>
                            <input type="text" value="${alloc.name}" onchange="updateAllocField(${index}, 'name', this.value)" class="w-full px-3 py-2 text-sm font-semibold rounded-lg border border-slate-200 focus:outline-none focus:ring-1 focus:ring-emerald-500">
                        </div>
                        <div class="md:col-span-3">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Porsi Persentase (%)</label>
                            <div class="relative">
                                <input type="number" value="${alloc.percent}" onchange="updateAllocField(${index}, 'percent', this.value)" min="1" max="100" class="w-full px-3 py-2 text-sm font-bold text-emerald-700 rounded-lg border border-slate-200 focus:outline-none focus:ring-1 focus:ring-emerald-500">
                                <span class="absolute right-3 top-2 text-slate-400 text-sm font-bold">%</span>
                            </div>
                        </div>
                        <div class="md:col-span-3">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Limit Bulan Ini (Info)</label>
                            <div class="text-xs font-bold text-slate-700 pt-2.5">
                                ${formatRupiah(alloc.limit)}
                            </div>
                        </div>
                        <div class="md:col-span-1 flex justify-end pt-4 md:pt-0">
                            <button onclick="removeAllocationRow(${index})" class="text-rose-500 hover:text-rose-700 p-2 rounded bg-rose-50 hover:bg-rose-100 transition border border-rose-100">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', rowHTML);
            });
            checkPercentageSum();
        }

        function updateAllocField(index, field, value) {
            if (field === 'percent') {
                state.allocations[index].percent = Math.max(0, parseInt(value) || 0);
            } else {
                state.allocations[index].name = value.trim();
            }
            checkPercentageSum();
        }

        function addNewAllocationRow() {
            state.allocations.push({
                id: 'all-' + Date.now(),
                name: 'Kategori Baru',
                percent: 0,
                limit: 0,
                spent: 0
            });
            renderAllocationsEditor();
        }

        function removeAllocationRow(index) {
            if (state.allocations.length <= 1) {
                showToast("Minimal harus memiliki 1 kategori alokasi!", false);
                return;
            }
            state.allocations.splice(index, 1);
            renderAllocationsEditor();
        }

        function checkPercentageSum() {
            let total = state.allocations.reduce((sum, item) => sum + item.percent, 0);
            const totalValEl = document.getElementById('total-pct-val');
            const totalBadge = document.getElementById('percentage-total-badge');

            totalValEl.textContent = total;

            if (total === 100) {
                totalBadge.className = "text-xs px-3 py-1 rounded-full font-bold bg-emerald-100 text-emerald-800";
            } else {
                totalBadge.className = "text-xs px-3 py-1 rounded-full font-bold bg-rose-100 text-rose-800";
            }
        }

        function saveAllocationsConfig() {
            let total = state.allocations.reduce((sum, item) => sum + item.percent, 0);
            if (total !== 100) {
                showToast("Gagal menyimpan! Total semua persentase alokasi harus genap 100%.", false);
                return;
            }

            let emptyCats = state.allocations.filter(a => !a.name.trim());
            if (emptyCats.length > 0) {
                showToast("Nama kategori tidak boleh ada yang kosong!", false);
                return;
            }

            calculateFinancialState();
            populateManualFormCategories();
            showToast("Pengaturan Kategori Alokasi Berhasil Diperbarui!");
        }

        function simulateQuickMessage(text) {
            document.getElementById('wa-text-input').value = text;
            handleSendMessage(new Event('submit'));
        }

        function handleSendMessage(e) {
            if(e) e.preventDefault();
            const input = document.getElementById('wa-text-input');
            const messageText = input.value.trim();

            if (!messageText) return;

            addChatMessage(messageText, 'user');
            input.value = '';

            setTimeout(() => {
                const response = processWAMockMessage(messageText);
                addChatMessage(response, 'bot');
            }, 800);
        }

        function addChatMessage(text, sender) {
            const chatBox = document.getElementById('chat-messages-container');
            const timeStr = new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });

            let msgHTML = '';
            if (sender === 'user') {
                msgHTML = `
                    <div class="max-w-[85%] self-end bg-[#d9fdd3] p-3 rounded-2xl rounded-tr-none shadow-sm text-xs text-slate-800 leading-relaxed border border-slate-100">
                        <p class="whitespace-pre-line font-medium">${text}</p>
                        <span class="text-[9px] text-slate-400 block text-right mt-1 font-mono">${timeStr} <i class="fa-solid fa-check-double text-blue-500"></i></span>
                    </div>
                `;
            } else {
                msgHTML = `
                    <div class="max-w-[85%] self-start bg-white p-3 rounded-2xl rounded-tl-none shadow-sm text-xs text-slate-800 leading-relaxed border border-slate-100">
                        <p class="font-semibold text-emerald-600 mb-1">KeuKita Bot 🤖</p>
                        <p class="whitespace-pre-line">${text}</p>
                        <span class="text-[9px] text-slate-400 block text-right mt-1 font-mono">${timeStr}</span>
                    </div>
                `;
            }

            chatBox.insertAdjacentHTML('beforeend', msgHTML);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        function processWAMockMessage(msg) {
            const normalized = msg.trim();
            const isIncome = normalized.startsWith("+");
            const isExpense = normalized.startsWith("-");
            const isStatusCheck = normalized.toLowerCase() === "status";

            if (isStatusCheck) {
                let totalIncome = state.transactions.filter(t => t.type === 'pemasukan').reduce((s, t) => s + t.amount, 0);
                let totalExpense = state.transactions.filter(t => t.type === 'pengeluaran').reduce((s, t) => s + t.amount, 0);
                let balance = totalIncome - totalExpense;

                let categoryLines = '';
                state.allocations.forEach(a => {
                    categoryLines += `\n• *${a.name}*: ${formatRupiah(a.spent)} / limit ${formatRupiah(a.limit)}`;
                });

                return `📊 *STATUS KEUANGAN RUMAH TANGGA*

📥 Total Pemasukan: *${formatRupiah(totalIncome)}*
📤 Total Pengeluaran: *${formatRupiah(totalExpense)}*
💰 *Sisa Saldo Kas: ${formatRupiah(balance)}*

*Breakdown Alokasi:*${categoryLines}

_Data tersinkron otomatis ke Google Sheets_`;
            }

            if (isIncome || isExpense) {
                const cleanText = normalized.substring(1).trim();
                const parts = cleanText.split(" ");
                const amount = parseFloat(parts[0].replace(/[^0-9]/g, ""));

                if (isNaN(amount) || amount <= 0) {
                    return `❌ *Format Gagal!*
Format nominal tidak valid. Contoh penulisan:
👉 \`+ 150000 Gaji sampingan\`
👉 \`- 45000 Beli Nasi bebek\``;
                }

                parts.shift();
                let textRemain = parts.join(" ");

                let category = "";
                let hashtagIndex = textRemain.indexOf("#");
                if (hashtagIndex !== -1) {
                    category = textRemain.substring(hashtagIndex + 1).trim();
                    textRemain = textRemain.substring(0, hashtagIndex).trim();
                }

                if (!category) {
                    category = isIncome ? 'Pembagian Auto' : 'Kebutuhan';
                }

                let matchedAlloc = state.allocations.find(a => a.name.toLowerCase() === category.toLowerCase());
                if (!isIncome && !matchedAlloc) {
                    category = state.allocations[0] ? state.allocations[0].name : 'Kebutuhan';
                }

                const newTx = {
                    id: 'tx-' + Date.now(),
                    date: new Date(),
                    type: isIncome ? 'pemasukan' : 'pengeluaran',
                    category: category,
                    amount: amount,
                    desc: textRemain || (isIncome ? 'Pemasukan Kas' : 'Pengeluaran Kas'),
                    source: 'WhatsApp'
                };

                state.transactions.unshift(newTx);
                calculateFinancialState();
                renderDashboard();
                renderTransactionsList();
                updateChart();

                const typeLabel = isIncome ? "📥 Pemasukan" : "📤 Pengeluaran";
                return `✅ *${typeLabel} Berhasil Dicatat!*
• Nominal: *${formatRupiah(amount)}*
• Keterangan: _${newTx.desc}_
• Alokasi: *${category}*

_Data tersimpan di Google Sheets!_`;
            }

            return `❓ *Format Tidak Dikenali*
Silakan kirim perintah transaksi Anda:
• *Pemasukan*: \`+ [nominal] [keterangan]\`
• *Pengeluaran*: \`- [nominal] [keterangan]\`

Ketik *status* untuk ringkasan keuangan.`;
        }

        /* 5. Chart JS Analytics Integration */
        function initChart() {
            const ctx = document.getElementById('expenseChart').getContext('2d');
            const labels = state.allocations.map(a => a.name);
            const data = state.allocations.map(a => a.spent);
            const backgroundColors = [
                'rgba(16, 185, 129, 0.85)',
                'rgba(59, 130, 246, 0.85)',
                'rgba(245, 158, 11, 0.85)',
                'rgba(99, 102, 241, 0.85)',
                'rgba(239, 68, 68, 0.85)'
            ];

            const totalExpense = data.reduce((s, val) => s + val, 0);
            if (totalExpense === 0) {
                document.getElementById('chart-no-data').classList.remove('hidden');
            } else {
                document.getElementById('chart-no-data').classList.add('hidden');
            }

            expenseChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: backgroundColors.slice(0, labels.length),
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'bottom',
                            labels: {
                                boxWidth: 12,
                                font: { size: 10, weight: 'semibold' },
                                padding: 10
                            }
                        }
                    },
                    cutout: '70%'
                }
            });
        }

        function updateChart() {
            if (!expenseChart) return;

            const labels = state.allocations.map(a => a.name);
            const data = state.allocations.map(a => a.spent);
            const totalExpense = data.reduce((s, val) => s + val, 0);

            if (totalExpense === 0) {
                document.getElementById('chart-no-data').classList.remove('hidden');
            } else {
                document.getElementById('chart-no-data').classList.add('hidden');
            }

            expenseChart.data.labels = labels;
            expenseChart.data.datasets[0].data = data;
            expenseChart.update();
        }

        function copyAppsScriptCode() {
            const textToCopy = document.getElementById('codeblock-area').textContent;
            const dummy = document.createElement("textarea");
            document.body.appendChild(dummy);
            dummy.value = textToCopy;
            dummy.select();
            document.execCommand("copy");
            document.body.removeChild(dummy);

            const copyBtnText = document.getElementById('copy-text');
            copyBtnText.textContent = 'Tersalin!';
            
            showToast("Kode Google Apps Script berhasil disalin!");
            
            setTimeout(() => {
                copyBtnText.textContent = 'Salin Kode';
            }, 2500);
        }
    </script>
</body>
</html>
