    </div>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200 mt-12 py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center text-xs text-slate-500 gap-4">
            <p>© 2026 KeuKita App. Platform Pengelola Keuangan Rumah Tangga dengan Integrasi Bot Pintar.</p>
            <div class="flex space-x-4">
                <a href="#" class="hover:text-slate-800 transition">Panduan Keuangan</a>
                <span>•</span>
                <a href="#" class="hover:text-slate-800 transition">Hubungi Pengembang</a>
